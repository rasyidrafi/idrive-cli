{
  "name": "idrive-cli",
  "version": "0.4.0",
  "description": "Unofficial headless CLI for IDrive Cloud Drive",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "idrive-cli": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "npm run typecheck && npm run lint && npm test",
    "dev": "tsx src/cli.ts",
    "lint": "eslint .",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check && npm run build",
    "test": "vitest run",
    "test:integration": "vitest run test/engine-installer.integration.test.ts",
    "test:live": "node scripts/live-test-preflight.mjs && vitest run test/live-account.integration.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "idrive",
    "cloud-drive",
    "cli"
  ],
  "author": "Muhammad Rasyid Rafi'i",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rasyidrafi/idrive-cli.git"
  },
  "bugs": {
    "url": "https://github.com/rasyidrafi/idrive-cli/issues"
  },
  "homepage": "https://github.com/rasyidrafi/idrive-cli#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "fast-xml-parser": "^5.10.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
